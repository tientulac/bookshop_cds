{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "moduleResolution": "bundler",
    "rootDir": "./webapp",
    "outDir": "./dist",
    "paths": {
      "hrcap/cts/periodconfig/periodconfig/*": [
        "./webapp/*"
      ]
    },
    "types": [
      "@sapui5/types"
    ]
  },
  "include": [
    "./webapp/**/*"
  ]
}
