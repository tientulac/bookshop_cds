<mvc:View controllerName="hrcap.cts.periodconfig.periodconfig.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" showHeader="false" enableScrolling="false">
        <f:DynamicPage id="periodConfigObjectPage" fitContent="true" preserveHeaderStateOnScroll="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:breadcrumbs>
                        <Breadcrumbs currentLocationText="Period Config">
                            <Link text="Home" />
                            <Link text="Payroll" />
                        </Breadcrumbs>
                    </f:breadcrumbs>
                    <f:heading>
                        <Title text="Period Configuration" level="H2" />
                    </f:heading>
                    <f:expandedContent>
                        <Label text="Manage confirmation windows by payroll period" />
                    </f:expandedContent>
                    <f:snappedContent>
                        <Text text="Maintain period dates and approval timeline" />
                    </f:snappedContent>
                    <f:actions>
                        <Button text="Edit" type="Emphasized" icon="sap-icon://edit" />
                    </f:actions>
                </f:DynamicPageTitle>
            </f:title>

            <f:header>
                <f:DynamicPageHeader>
                    <VBox>
                        <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
                            <VBox class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <Label text="Payroll Period" design="Bold" />
                                <ObjectIdentifier title="04.2026" />
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                                <Label text="Period Range" design="Bold" />
                                <Text text="2026-04-01 to 2026-04-30" />
                            </VBox>
                            <VBox class="sapUiTinyMarginBottom">
                                <Label text="Confirmation Window" design="Bold" />
                                <Text text="2026-05-01 to 2026-05-05" />
                            </VBox>
                        </HBox>

                        <fb:FilterBar id="periodConfigFilterBar" useToolbar="false" class="sapUiTinyMarginTop">
                            <fb:filterGroupItems>
                                <fb:FilterGroupItem groupName="__basic" name="payrollPeriod" label="Payroll Period" visibleInFilterBar="true">
                                    <fb:control>
                                        <Input id="filterPayrollPeriod" width="12rem" placeholder="MM.YYYY" />
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem groupName="__basic" name="payrollPeriodFrom" label="Payroll Period From" visibleInFilterBar="true">
                                    <fb:control>
                                        <DatePicker id="filterPayrollPeriodFrom" width="12rem" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" />
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem groupName="__basic" name="payrollPeriodTo" label="Payroll Period To" visibleInFilterBar="true">
                                    <fb:control>
                                        <DatePicker id="filterPayrollPeriodTo" width="12rem" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" />
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem groupName="__basic" name="confirmStartDate" label="Confirm Start Date" visibleInFilterBar="true">
                                    <fb:control>
                                        <DatePicker id="filterConfirmStartDate" width="12rem" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" />
                                    </fb:control>
                                </fb:FilterGroupItem>
                                <fb:FilterGroupItem groupName="__basic" name="confirmEndDate" label="Confirm End Date" visibleInFilterBar="true">
                                    <fb:control>
                                        <DatePicker id="filterConfirmEndDate" width="12rem" displayFormat="yyyy-MM-dd" valueFormat="yyyy-MM-dd" />
                                    </fb:control>
                                </fb:FilterGroupItem>
                            </fb:filterGroupItems>
                        </fb:FilterBar>
                    </VBox>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <VBox class="sapUiContentPadding">
                    <Panel headerText="Periods" expandable="false">
                        <t:Table
                            id="periodConfigTable"
                            rows="{table>/items}"
                            visibleRowCount="8"
                            selectionMode="None"
                            enableBusyIndicator="true"
                            busy="{table>/busy}"
                            width="auto">
                            <t:columns>
                                <t:Column>
                                    <Label text="Payroll Period" />
                                    <t:template>
                                        <Text text="{table>payrollPeriod}" />
                                    </t:template>
                                </t:Column>
                                <t:Column>
                                    <Label text="From" />
                                    <t:template>
                                        <Text text="{ path: 'table>payrollPeriodFrom', formatter: '.formatter.formatDate' }" />
                                    </t:template>
                                </t:Column>
                                <t:Column>
                                    <Label text="To" />
                                    <t:template>
                                        <Text text="{ path: 'table>payrollPeriodTo', formatter: '.formatter.formatDate' }" />
                                    </t:template>
                                </t:Column>
                                <t:Column>
                                    <Label text="Confirm Start" />
                                    <t:template>
                                        <Text text="{ path: 'table>confirmStartDate', formatter: '.formatter.formatDate' }" />
                                    </t:template>
                                </t:Column>
                                <t:Column>
                                    <Label text="Confirm End" />
                                    <t:template>
                                        <Text text="{ path: 'table>confirmEndDate', formatter: '.formatter.formatDate' }" />
                                    </t:template>
                                </t:Column>
                            </t:columns>
                        </t:Table>
                    </Panel>
                </VBox>
            </f:content>
        </f:DynamicPage>
    </Page>
</mvc:View>