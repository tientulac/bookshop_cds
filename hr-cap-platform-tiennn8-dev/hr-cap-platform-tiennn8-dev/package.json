{
  "name": "hr-cap-platform",
  "version": "1.0.0",
  "description": "HR CAP Platform Application",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "cds watch confirm-timesheet --open http://localhost:4004",
    "build": "mbt build -t gen --mtar mta.tar",
    "deploy": "npm run build && cf deploy gen/mta.tar",
    "undeploy": "cf undeploy hrcap --delete-services --delete-service-keys",
    "build:confirm-timesheet": "mkdir -p confirm-timesheet/gen",
    "build:shared-service": "npx cds build shared-service --for nodejs --production --ws-pack && cp package-lock.json shared-service/gen/srv/package-lock.json && cd shared-service/gen/srv && npm install --package-lock-only"
  },
  "author": "",
  "license": "UNLICENSED",
  "private": "true",
  "workspaces": [
    "confirm-timesheet",
    "confirm-timesheet/app/*",
    "shared-db",
    "shared-service"
  ],
  "dependencies": {
    "@sap/cds": "^9.8.5",
    "@sap/cds-dk": "^9.8.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.2.0"
  }
}
