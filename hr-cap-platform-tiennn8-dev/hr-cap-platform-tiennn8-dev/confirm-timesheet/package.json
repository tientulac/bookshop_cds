{
  "name": "@hrcap/confirm-timesheet",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/postgres": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.16.3",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-no-confirm": "cds watch --open hrcap.cts.noconfirm/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "imports": {
