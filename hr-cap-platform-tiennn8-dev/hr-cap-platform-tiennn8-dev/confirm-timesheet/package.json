        "impl": "@cap-js/postgres",
        "credentials": {
          "host": "localhost",
          "port": 5431,
          "database": "hr-cap-db",
          "user": "hr_admin",
          "password": "hr_admin"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "html5-repo": true
    }
  },
  "sapux": [
    "app/no-confirm"
  ]
}
